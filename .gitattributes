# KiCad text files — store as LF for clean cross-platform diffs
*.kicad_pcb     text eol=lf
*.kicad_sch    text eol=lf
*.kicad_pro    text eol=lf
*.kicad_mod    text eol=lf
*.kicad_sym    text eol=lf
*.kicad_prl    text eol=lf
*.kicad_dru    text eol=lf
*.kicad_wks    text eol=lf
fp-lib-table   text eol=lf
sym-lib-table  text eol=lf

# STM32CubeMX project files
*.ioc          text eol=lf

# 3D CAD models — binary data
*.step         binary
*.STEP         binary
*.stp          binary
*.STP          binary
*.wrl          binary
*.WRL          binary

# Datasheets and images
*.pdf          binary
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
